{
  "name": "promptconduit",
  "displayName": "PromptConduit",
  "description": "Local, real-time visibility into your AI coding sessions — live token cost in the status bar, a 3D Orchestration Theater that replays how your agents work, and an offline Agent Coaching report. 100% local.",
  "version": "0.7.0",
  "publisher": "promptconduit",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "cursor",
    "agent",
    "orchestration",
    "visualization",
    "observability",
    "telemetry",
    "token",
    "cost",
    "usage"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/promptconduit/editor-extension.git"
  },
  "bugs": {
    "url": "https://github.com/promptconduit/editor-extension/issues"
  },
  "homepage": "https://github.com/promptconduit/editor-extension#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptconduit.cost.showDetails",
        "title": "PromptConduit: Show Cost Breakdown"
      },
      {
        "command": "promptconduit.events.showFeed",
        "title": "PromptConduit: Show Telemetry Panel"
      },
      {
        "command": "promptconduit.coaching.showTab",
        "title": "PromptConduit: Show Agent Coaching"
      },
      {
        "command": "promptconduit.visualizer.show",
        "title": "PromptConduit: Show Orchestration Theater"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "promptconduitTelemetry",
          "title": "PromptConduit",
          "icon": "resources/telemetry.svg"
        }
      ]
    },
    "views": {
      "promptconduitTelemetry": [
        {
          "id": "promptconduit.telemetry",
          "name": "Telemetry",
          "type": "webview",
          "contextualTitle": "PromptConduit Telemetry"
        },
        {
          "id": "promptconduit.coaching",
          "name": "Coaching",
          "type": "webview",
          "contextualTitle": "PromptConduit Agent Coaching"
        }
      ]
    },
    "configuration": {
      "title": "PromptConduit",
      "properties": {
        "promptconduit.cost.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the realtime token-cost item in the status bar."
        },
        "promptconduit.cost.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the promptconduit CLI. Leave blank to auto-detect on PATH and common Homebrew locations."
        },
        "promptconduit.visualizer.githubEnrichment": {
          "type": "string",
          "enum": ["fetch", "inferOnly", "off"],
          "enumDescriptions": [
            "Fetch issue/PR titles and status from github.com (sends only owner/repo/number for the current repo).",
            "Infer issue/PR numbers from branch and commit messages, but make no network calls.",
            "Show no GitHub links on Orchestration Theater hover cards."
          ],
          "default": "fetch",
          "description": "How the Orchestration Theater resolves the GitHub issue/PR shown on hover cards."
        },
        "promptconduit.visualizer.githubToken": {
          "type": "string",
          "default": "",
          "description": "Optional GitHub token for issue/PR enrichment (raises the API rate limit and reaches private repos). Falls back to the GITHUB_TOKEN/GH_TOKEN environment variable."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node scripts/build-webview.mjs",
    "build:webview": "node scripts/build-webview.mjs",
    "typecheck:webview": "tsc -p tsconfig.webview.json",
    "watch": "node scripts/build-webview.mjs --watch & tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish",
    "dev": "bash scripts/dev.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview": "vite-node dev/preview.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.11.0",
    "@types/three": "^0.169.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.2",
    "ovsx": "^0.10.0",
    "three": "^0.169.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.6"
  }
}
