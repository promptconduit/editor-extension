# Ship only the runtime: out/ (compiled JS), resources/, and media/ (the webview
# bundle), plus README, CHANGELOG, LICENSE, and package.json. Everything below is
# dev-only and has no place in an installed extension.

# deps & build inputs
node_modules/
src/**
webview/**
*.config.ts
tsconfig.json
tsconfig.webview.json

# dev / test / docs tooling
.vscode/**
.vscode-test/
.github/**
test/**
dev/**
scripts/**
docs/**
DEVELOPING.md
CONTRIBUTING.md

# repo / packaging cruft
.gitignore
.gitattributes
.vscodeignore
*.vsix
package-lock.json

# sourcemaps (ship code, not maps)
media/*.map
out/**/*.map

# README/marketplace screenshots are referenced by absolute raw URL, so they
# don't need to bloat the installed VSIX (they live in git for the raw links).
resources/screenshots/**
